# ─── Django Core ───
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ───
# Leave blank for SQLite (default). Set for PostgreSQL:
# DATABASE_URL=postgres://user:pass@localhost:5432/cadencea

# ─── CORS (comma-separated origins) ───
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Cloudflare R2 Storage ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cadencea-media
R2_PUBLIC_URL=
# Set to 'r2' to use Cloudflare R2, leave blank for local filesystem
STORAGE_BACKEND=local

# ─── External API Keys ───
MUSICBRAINZ_USER_AGENT=Cadencea/1.0.0 (your-email@example.com)
JAMENDO_CLIENT_ID=
LRCLIB_BASE_URL=https://lrclib.net

# ─── JWT Settings ───
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7
